{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClickHouse Secret",
  "description": "Goldsky secret schema for ClickHouse database connections",
  "type": "object",
  "required": ["type", "url", "username", "password", "databaseName"],
  "properties": {
    "type": {
      "type": "string",
      "const": "clickHouse",
      "description": "Secret type identifier"
    },
    "url": {
      "type": "string",
      "description": "ClickHouse HTTP interface URL",
      "pattern": "^https?://",
      "examples": ["https://xyz.clickhouse.cloud:8443"]
    },
    "username": {
      "type": "string",
      "description": "ClickHouse username",
      "default": "default"
    },
    "password": {
      "type": "string",
      "description": "ClickHouse password"
    },
    "databaseName": {
      "type": "string",
      "description": "Target database name",
      "default": "default"
    }
  },
  "examples": [
    {
      "type": "clickHouse",
      "url": "https://xyz.clickhouse.cloud:8443",
      "username": "default",
      "password": "your-password-here",
      "databaseName": "default"
    }
  ]
}
