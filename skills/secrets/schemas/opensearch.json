{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenSearch Secret",
  "description": "Goldsky secret schema for OpenSearch connections",
  "type": "object",
  "required": ["type", "host", "username", "password"],
  "properties": {
    "type": {
      "type": "string",
      "const": "opensearch",
      "description": "Secret type identifier"
    },
    "host": {
      "type": "string",
      "description": "OpenSearch host URL with port",
      "pattern": "^https?://",
      "examples": ["https://my-domain.us-east-1.es.amazonaws.com:443"]
    },
    "username": {
      "type": "string",
      "description": "OpenSearch username",
      "examples": ["admin"]
    },
    "password": {
      "type": "string",
      "description": "OpenSearch password"
    }
  },
  "examples": [
    {
      "type": "opensearch",
      "host": "https://my-domain.us-east-1.es.amazonaws.com:443",
      "username": "admin",
      "password": "your-password-here"
    }
  ]
}
