{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Webhook Secret",
  "description": "Goldsky secret schema for webhook HTTP authentication",
  "type": "object",
  "required": ["type", "secretKey", "secretValue"],
  "properties": {
    "type": {
      "type": "string",
      "const": "httpauth",
      "description": "Secret type identifier"
    },
    "secretKey": {
      "type": "string",
      "description": "HTTP header name for authentication",
      "examples": ["Authorization", "X-API-Key", "X-Webhook-Secret"]
    },
    "secretValue": {
      "type": "string",
      "description": "HTTP header value (e.g., Bearer token or API key)",
      "examples": ["Bearer your-token", "sk_live_xxx"]
    }
  },
  "examples": [
    {
      "type": "httpauth",
      "secretKey": "Authorization",
      "secretValue": "Bearer your-token-here"
    },
    {
      "type": "httpauth",
      "secretKey": "X-API-Key",
      "secretValue": "your-api-key-here"
    }
  ]
}
