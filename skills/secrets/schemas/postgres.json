{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostgreSQL Secret",
  "description": "Goldsky secret schema for PostgreSQL/MySQL database connections",
  "type": "object",
  "required": [
    "type",
    "protocol",
    "host",
    "port",
    "databaseName",
    "user",
    "password"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "jdbc",
      "description": "Secret type identifier"
    },
    "protocol": {
      "type": "string",
      "enum": ["postgres", "mysql"],
      "description": "Database protocol (postgres or mysql)"
    },
    "host": {
      "type": "string",
      "description": "Database hostname (without port)",
      "examples": ["db.example.com", "ep-cool-name.us-east-2.aws.neon.tech"]
    },
    "port": {
      "type": "integer",
      "description": "Database port (5432 for PostgreSQL, 3306 for MySQL)",
      "default": 5432
    },
    "databaseName": {
      "type": "string",
      "description": "Name of the database to connect to",
      "examples": ["mydb", "neondb", "postgres"]
    },
    "user": {
      "type": "string",
      "description": "Database username",
      "examples": ["admin", "neondb_owner", "postgres"]
    },
    "password": {
      "type": "string",
      "description": "Database password"
    }
  },
  "examples": [
    {
      "type": "jdbc",
      "protocol": "postgres",
      "host": "ep-cool-name.us-east-2.aws.neon.tech",
      "port": 5432,
      "databaseName": "neondb",
      "user": "neondb_owner",
      "password": "your-password-here"
    }
  ]
}
