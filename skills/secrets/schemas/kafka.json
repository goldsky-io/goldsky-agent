{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kafka Secret",
  "description": "Goldsky secret schema for Kafka connections",
  "type": "object",
  "required": ["type", "bootstrapServers", "securityProtocol"],
  "properties": {
    "type": {
      "type": "string",
      "const": "kafka",
      "description": "Secret type identifier"
    },
    "bootstrapServers": {
      "type": "string",
      "description": "Comma-separated list of Kafka broker addresses",
      "examples": ["broker:9092", "broker1:9092,broker2:9092"]
    },
    "securityProtocol": {
      "type": "string",
      "enum": ["PLAINTEXT", "SASL_PLAINTEXT", "SASL_SSL", "SSL"],
      "description": "Kafka security protocol"
    },
    "saslMechanism": {
      "type": "string",
      "enum": ["PLAIN", "SCRAM-SHA-256", "SCRAM-SHA-512"],
      "description": "SASL authentication mechanism (required for SASL_* protocols)"
    },
    "saslJaasUsername": {
      "type": "string",
      "description": "SASL username (required for SASL_* protocols)"
    },
    "saslJaasPassword": {
      "type": "string",
      "description": "SASL password (required for SASL_* protocols)"
    }
  },
  "examples": [
    {
      "type": "kafka",
      "bootstrapServers": "broker:9092",
      "securityProtocol": "SASL_SSL",
      "saslMechanism": "PLAIN",
      "saslJaasUsername": "user",
      "saslJaasPassword": "your-password-here"
    }
  ]
}
