{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AWS DynamoDB Secret",
  "description": "Goldsky secret schema for AWS DynamoDB access",
  "type": "object",
  "required": ["type", "accessKey", "secretAccessKey", "region"],
  "properties": {
    "type": {
      "type": "string",
      "const": "dynamodb",
      "description": "Secret type identifier"
    },
    "accessKey": {
      "type": "string",
      "description": "AWS Access Key ID",
      "pattern": "^AKIA",
      "examples": ["AKIAIOSFODNN7EXAMPLE"]
    },
    "secretAccessKey": {
      "type": "string",
      "description": "AWS Secret Access Key"
    },
    "region": {
      "type": "string",
      "description": "AWS region",
      "examples": ["us-east-1", "us-west-2", "eu-west-1"]
    }
  },
  "examples": [
    {
      "type": "dynamodb",
      "accessKey": "AKIAIOSFODNN7EXAMPLE",
      "secretAccessKey": "your-secret-key-here",
      "region": "us-east-1"
    }
  ]
}
