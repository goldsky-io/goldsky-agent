{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ElasticSearch Secret",
  "description": "Goldsky secret schema for ElasticSearch connections",
  "type": "object",
  "required": ["type", "host", "username", "password"],
  "properties": {
    "type": {
      "type": "string",
      "const": "elasticSearch",
      "description": "Secret type identifier"
    },
    "host": {
      "type": "string",
      "description": "ElasticSearch host URL with port",
      "pattern": "^https?://",
      "examples": ["https://my-cluster.us-central1.gcp.cloud.es.io:443"]
    },
    "username": {
      "type": "string",
      "description": "ElasticSearch username",
      "examples": ["elastic"]
    },
    "password": {
      "type": "string",
      "description": "ElasticSearch password"
    }
  },
  "examples": [
    {
      "type": "elasticSearch",
      "host": "https://my-cluster.us-central1.gcp.cloud.es.io:443",
      "username": "elastic",
      "password": "your-password-here"
    }
  ]
}
