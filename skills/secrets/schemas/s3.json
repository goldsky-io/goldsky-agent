{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AWS S3 Secret",
  "description": "Goldsky secret schema for AWS S3 bucket access",
  "type": "object",
  "required": ["type", "accessKeyId", "secretAccessKey", "region"],
  "properties": {
    "type": {
      "type": "string",
      "const": "s3",
      "description": "Secret type identifier"
    },
    "accessKeyId": {
      "type": "string",
      "description": "AWS Access Key ID",
      "pattern": "^AKIA",
      "examples": ["AKIAIOSFODNN7EXAMPLE"]
    },
    "secretAccessKey": {
      "type": "string",
      "description": "AWS Secret Access Key"
    },
    "region": {
      "type": "string",
      "description": "AWS region",
      "examples": ["us-east-1", "us-west-2", "eu-west-1"]
    }
  },
  "examples": [
    {
      "type": "s3",
      "accessKeyId": "AKIAIOSFODNN7EXAMPLE",
      "secretAccessKey": "your-secret-key-here",
      "region": "us-east-1"
    }
  ]
}
