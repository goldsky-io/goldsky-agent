{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Chain prefixes for Goldsky dataset names",
  "lastUpdated": "2025-01-29",
  "evmChains": [
    {
      "name": "Ethereum Mainnet",
      "prefix": "ethereum",
      "chainId": 1,
      "example": "ethereum.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Base",
      "prefix": "base",
      "chainId": 8453,
      "example": "base.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Polygon",
      "prefix": "matic",
      "chainId": 137,
      "example": "matic.erc20_transfers",
      "note": "Use 'matic' not 'polygon'",
      "status": "production"
    },
    {
      "name": "Arbitrum One",
      "prefix": "arbitrum",
      "chainId": 42161,
      "example": "arbitrum.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Optimism",
      "prefix": "optimism",
      "chainId": 10,
      "example": "optimism.erc20_transfers",
      "status": "production"
    },
    {
      "name": "BNB Smart Chain",
      "prefix": "bsc",
      "chainId": 56,
      "example": "bsc.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Avalanche C-Chain",
      "prefix": "avalanche",
      "chainId": 43114,
      "example": "avalanche.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Fantom",
      "prefix": "fantom",
      "chainId": 250,
      "example": "fantom.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Gnosis Chain",
      "prefix": "gnosis",
      "chainId": 100,
      "example": "gnosis.erc20_transfers",
      "status": "production"
    },
    {
      "name": "Linea",
      "prefix": "linea",
      "chainId": 59144,
      "example": "linea.erc20_transfers",
      "status": "production"
    },
    {
      "name": "zkSync Era",
      "prefix": "zksync",
      "chainId": 324,
      "example": "zksync.erc20_transfers",
      "status": "production"
    }
  ],
  "nonEvmChains": [
    {
      "name": "Solana",
      "prefix": "solana",
      "example": "solana.token_transfers",
      "note": "Uses start_block (slot) instead of start_at",
      "status": "production"
    },
    {
      "name": "Bitcoin",
      "prefix": "bitcoin.raw",
      "example": "bitcoin.raw.transactions",
      "note": "Uses start_at like EVM",
      "status": "production"
    },
    {
      "name": "Stellar",
      "prefix": "stellar_mainnet",
      "example": "stellar_mainnet.transfers",
      "note": "Uses start_at like EVM, datasets use v1.1.0",
      "status": "production"
    },
    {
      "name": "Sui",
      "prefix": "sui",
      "example": "sui.transactions",
      "note": "Uses start_at like EVM",
      "status": "production"
    },
    {
      "name": "NEAR",
      "prefix": "near",
      "example": "near.receipts",
      "note": "Uses start_at like EVM",
      "status": "production"
    },
    {
      "name": "Starknet",
      "prefix": "starknet",
      "example": "starknet.events",
      "note": "Uses start_at like EVM",
      "status": "production"
    },
    {
      "name": "Fogo",
      "prefix": "fogo",
      "example": "fogo.transactions_with_instructions",
      "note": "Uses start_at like EVM",
      "status": "production"
    }
  ],
  "commonMistakes": [
    {
      "wrong": "polygon",
      "correct": "matic",
      "note": "Polygon uses 'matic' prefix"
    },
    {
      "wrong": "eth",
      "correct": "ethereum",
      "note": "Use full 'ethereum' prefix"
    },
    {
      "wrong": "arb",
      "correct": "arbitrum",
      "note": "Use full 'arbitrum' prefix"
    },
    {
      "wrong": "op",
      "correct": "optimism",
      "note": "Use full 'optimism' prefix"
    }
  ]
}
