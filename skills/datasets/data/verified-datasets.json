{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Verified Goldsky datasets - these have been tested and confirmed to work",
  "lastUpdated": "2025-01-29",
  "datasets": {
    "erc20_transfers": {
      "description": "ERC-20 token transfers",
      "useCase": "Token tracking, DeFi analytics, wallet monitoring",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true },
        "base": { "version": "1.2.0", "startAtSupport": true },
        "matic": { "version": "1.0.0", "startAtSupport": true },
        "arbitrum": { "version": "1.0.0", "startAtSupport": true },
        "optimism": { "version": "1.0.0", "startAtSupport": true },
        "bsc": { "version": "1.0.0", "startAtSupport": true },
        "avalanche": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "sender": "string",
        "recipient": "string",
        "amount": "decimal",
        "address": "string (token contract address)",
        "block_number": "integer",
        "block_timestamp": "integer (unix)",
        "block_hash": "string",
        "transaction_hash": "string",
        "transaction_index": "integer",
        "log_index": "integer"
      }
    },
    "erc721_transfers": {
      "description": "ERC-721 NFT transfers",
      "useCase": "NFT marketplaces, ownership tracking, collection analytics",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true },
        "base": { "version": "1.0.0", "startAtSupport": true },
        "matic": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "from_address": "string",
        "to_address": "string",
        "token_id": "decimal",
        "address": "string (NFT contract address)",
        "block_number": "integer",
        "block_timestamp": "integer (unix)",
        "block_hash": "string",
        "transaction_hash": "string",
        "transaction_index": "integer",
        "log_index": "integer"
      }
    },
    "raw_transactions": {
      "description": "Enriched transaction data including receipt fields (NOT 'transactions')",
      "useCase": "Wallet activity, gas analysis, transaction monitoring",
      "warning": "Use 'raw_transactions' not 'transactions'",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true },
        "base": { "version": "1.0.0", "startAtSupport": true },
        "matic": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "hash": "string",
        "nonce": "integer",
        "block_hash": "string",
        "block_number": "integer",
        "transaction_index": "integer",
        "from_address": "string",
        "to_address": "string",
        "value": "decimal",
        "gas": "decimal",
        "gas_price": "decimal",
        "input": "string (hex)",
        "max_fee_per_gas": "decimal",
        "max_priority_fee_per_gas": "decimal",
        "transaction_type": "integer",
        "block_timestamp": "integer (unix)",
        "receipt_cumulative_gas_used": "decimal",
        "receipt_gas_used": "decimal",
        "receipt_contract_address": "string | null",
        "receipt_status": "integer (1=success)",
        "receipt_effective_gas_price": "decimal",
        "_note": "L2 chains also include receipt_l1_fee, receipt_l1_gas_used, receipt_l1_gas_price"
      }
    },
    "logs": {
      "description": "Event logs from smart contracts",
      "useCase": "Custom event filtering, contract monitoring",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true },
        "base": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "block_number": "integer",
        "block_hash": "string",
        "transaction_hash": "string",
        "transaction_index": "integer",
        "log_index": "integer",
        "address": "string (contract address)",
        "data": "string (hex encoded event data)",
        "topics": "string (comma-separated hex topic hashes)",
        "block_timestamp": "integer (unix)"
      }
    },
    "raw_logs": {
      "description": "Raw event logs — same schema as logs, check availability per chain",
      "useCase": "Custom event filtering, contract monitoring",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "block_number": "integer",
        "block_hash": "string",
        "transaction_hash": "string",
        "transaction_index": "integer",
        "log_index": "integer",
        "address": "string (contract address)",
        "data": "string (hex encoded event data)",
        "topics": "string (comma-separated hex topic hashes)",
        "block_timestamp": "integer (unix)"
      }
    },
    "blocks": {
      "description": "Block headers and metadata",
      "useCase": "Block explorers, timing analysis, chain health",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true },
        "base": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "number": "integer",
        "hash": "string",
        "parent_hash": "string",
        "nonce": "string",
        "miner": "string",
        "difficulty": "double",
        "total_difficulty": "double",
        "size": "integer",
        "gas_limit": "integer",
        "gas_used": "integer",
        "timestamp": "integer (unix)",
        "transaction_count": "integer",
        "base_fee_per_gas": "integer"
      }
    },
    "raw_blocks": {
      "description": "Raw block data — same schema as blocks, check availability per chain",
      "useCase": "Same as blocks",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true }
      }
    },
    "traces": {
      "description": "Internal transactions and call traces",
      "useCase": "MEV analysis, contract interactions, deep transaction analysis",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true }
      },
      "schema": {
        "id": "string",
        "block_number": "integer",
        "block_hash": "string",
        "transaction_hash": "string",
        "transaction_index": "integer",
        "from_address": "string",
        "to_address": "string",
        "value": "decimal",
        "input": "string",
        "output": "string",
        "trace_type": "string",
        "call_type": "string",
        "gas": "integer",
        "gas_used": "integer",
        "subtraces": "integer",
        "trace_address": "string",
        "error": "string | null",
        "status": "integer",
        "trace_id": "string",
        "block_timestamp": "integer (unix)"
      }
    },
    "decoded_logs": {
      "description": "ABI-decoded event logs",
      "useCase": "Specific contract events with human-readable data",
      "chains": {
        "ethereum": { "version": "1.0.0", "startAtSupport": true }
      }
    }
  },
  "solana": {
    "token_transfers": {
      "description": "SPL token transfers on Solana",
      "version": "1.0.0",
      "datasetName": "solana.token_transfers",
      "useCase": "Token tracking on Solana",
      "note": "Uses start_block (slot number) instead of start_at",
      "schema": {
        "id": "string",
        "token_mint_address": "string",
        "from_token_account": "string",
        "to_token_account": "string",
        "amount": "number",
        "decimals": "integer",
        "block_slot": "integer",
        "block_timestamp": "timestamp",
        "signature": "string"
      }
    },
    "transactions": {
      "description": "Solana transactions with accounts and balances",
      "version": "1.0.0",
      "datasetName": "solana.transactions",
      "useCase": "Wallet activity, transaction monitoring",
      "schema": {
        "id": "string",
        "index": "integer",
        "block_slot": "integer",
        "block_hash": "string",
        "block_timestamp": "timestamp",
        "accounts": "string[] (all accounts involved in tx)",
        "balance_changes": "object[] {account: string, before: integer, after: integer}",
        "recent_block_hash": "string",
        "signature": "string",
        "err": "string | null",
        "status": "integer (1=success)",
        "compute_units_consumed": "integer",
        "fee": "integer (lamports)",
        "log_messages": "string[]"
      }
    },
    "transactions_with_instructions": {
      "description": "Solana transactions with nested instructions array",
      "version": "1.0.0",
      "datasetName": "solana.transactions_with_instructions",
      "useCase": "Multi-instruction analysis, program interaction tracking",
      "schema": {
        "id": "string",
        "index": "integer",
        "block_slot": "integer",
        "block_hash": "string",
        "block_timestamp": "timestamp",
        "accounts": "string[] (all accounts involved in tx)",
        "balance_changes": "object[] {account: string, before: integer, after: integer}",
        "pre_token_balances": "object[]",
        "post_token_balances": "object[]",
        "recent_block_hash": "string",
        "signature": "string",
        "err": "string | null",
        "status": "integer (1=success)",
        "compute_units_consumed": "integer",
        "fee": "integer (lamports)",
        "log_messages": "string[]",
        "instructions": "object[] {id, index, parent_index, block_slot, block_timestamp, block_hash, tx_fee, tx_index, program_id, data (base58), accounts: string[], status, err}"
      }
    },
    "instructions": {
      "description": "Individual Solana instructions (one row per instruction)",
      "version": "1.0.0",
      "datasetName": "solana.instructions",
      "useCase": "Program-specific analysis, instruction-level filtering",
      "schema": {
        "id": "string",
        "index": "integer",
        "parent_index": "integer | null",
        "block_slot": "integer",
        "block_timestamp": "timestamp",
        "block_hash": "string",
        "program_id": "string",
        "data": "string (base58 encoded instruction data)",
        "accounts": "string[]",
        "status": "integer",
        "err": "string | null"
      }
    },
    "blocks": {
      "description": "Solana block/slot data with leader info",
      "version": "1.0.0",
      "datasetName": "solana.blocks",
      "useCase": "Chain analysis, slot timing",
      "schema": {
        "id": "string",
        "slot": "integer",
        "parent_slot": "integer",
        "hash": "string",
        "timestamp": "timestamp",
        "height": "integer",
        "previous_block_hash": "string",
        "transaction_count": "integer",
        "leader_reward": "integer (lamports)",
        "leader": "string (validator pubkey)",
        "skipped": "boolean"
      }
    },
    "native_balances": {
      "description": "SOL balance changes per transaction",
      "version": "1.0.0",
      "datasetName": "solana.native_balances",
      "useCase": "Whale tracking, SOL flow analysis",
      "schema": {
        "id": "string",
        "account": "string",
        "amount_before": "integer (lamports)",
        "amount_after": "integer (lamports)",
        "block_slot": "integer"
      }
    },
    "token_balances": {
      "description": "SPL token balance changes",
      "version": "1.0.0",
      "datasetName": "solana.token_balances",
      "useCase": "Portfolio tracking, token holder analysis",
      "schema": "NOT FULLY DOCUMENTED — use 'goldsky dataset list | grep solana.token_balances' to inspect actual fields before writing transforms"
    },
    "rewards": {
      "description": "Validator rewards per block",
      "version": "1.0.0",
      "datasetName": "solana.rewards",
      "useCase": "Staking analysis, validator performance",
      "schema": {
        "id": "string",
        "block_slot": "integer",
        "block_hash": "string",
        "block_timestamp": "timestamp",
        "commission": "integer",
        "lamports": "integer",
        "post_balance": "integer",
        "pub_key": "string (validator pubkey)",
        "reward_type": "string"
      }
    }
  },
  "bitcoin": {
    "blocks": {
      "description": "Bitcoin block data (hash, difficulty, size)",
      "version": "1.0.0",
      "datasetName": "bitcoin.raw.blocks",
      "useCase": "Network analysis, mining statistics"
    },
    "transactions": {
      "description": "Bitcoin transactions (inputs, outputs, values)",
      "version": "1.0.0",
      "datasetName": "bitcoin.raw.transactions",
      "useCase": "Payment tracking, UTXO analysis"
    }
  },
  "stellar": {
    "transactions": {
      "description": "All Stellar network transactions",
      "version": "1.1.0",
      "datasetName": "stellar_mainnet.transactions",
      "useCase": "Account monitoring"
    },
    "transfers": {
      "description": "All transfer events on Stellar",
      "version": "1.1.0",
      "datasetName": "stellar_mainnet.transfers",
      "useCase": "Asset tracking, payment monitoring"
    },
    "events": {
      "description": "All events (contract + operation)",
      "version": "1.1.0",
      "datasetName": "stellar_mainnet.events",
      "useCase": "Contract monitoring"
    },
    "operations": {
      "description": "Operations within transactions",
      "version": "1.1.0",
      "datasetName": "stellar_mainnet.operations",
      "useCase": "Action tracking"
    },
    "balances": {
      "description": "Account balance changes",
      "version": "1.1.0",
      "datasetName": "stellar_mainnet.balances",
      "useCase": "Balance tracking"
    }
  },
  "sui": {
    "checkpoints": {
      "description": "Sui checkpoint data",
      "version": "1.0.0",
      "datasetName": "sui.checkpoints",
      "useCase": "Chain analysis"
    },
    "transactions": {
      "description": "Sui transaction data",
      "version": "1.0.0",
      "datasetName": "sui.transactions",
      "useCase": "Activity monitoring"
    },
    "events": {
      "description": "Move contract events on Sui",
      "version": "1.0.0",
      "datasetName": "sui.events",
      "useCase": "dApp event tracking"
    },
    "packages": {
      "description": "Deployed Move packages",
      "version": "1.0.0",
      "datasetName": "sui.packages",
      "useCase": "Package discovery"
    },
    "epochs": {
      "description": "Epoch data with validators",
      "version": "1.0.0",
      "datasetName": "sui.epochs",
      "useCase": "Staking and validator analysis"
    }
  },
  "near": {
    "receipts": {
      "description": "Execution receipts on NEAR",
      "version": "1.0.0",
      "datasetName": "near.receipts",
      "useCase": "Contract interaction tracking"
    },
    "transactions": {
      "description": "Signed NEAR transactions",
      "version": "1.0.0",
      "datasetName": "near.transactions",
      "useCase": "Activity monitoring"
    },
    "execution_outcomes": {
      "description": "Execution results on NEAR",
      "version": "1.0.0",
      "datasetName": "near.execution_outcomes",
      "useCase": "Success/failure analysis"
    }
  },
  "starknet": {
    "blocks": {
      "description": "Starknet block data",
      "version": "1.0.0",
      "datasetName": "starknet.blocks",
      "useCase": "Chain analysis"
    },
    "transactions": {
      "description": "Starknet transaction data",
      "version": "1.0.0",
      "datasetName": "starknet.transactions",
      "useCase": "Activity monitoring"
    },
    "events": {
      "description": "Starknet contract events",
      "version": "1.0.0",
      "datasetName": "starknet.events",
      "useCase": "dApp event tracking"
    },
    "messages": {
      "description": "L1 to L2 messages on Starknet",
      "version": "1.0.0",
      "datasetName": "starknet.messages",
      "useCase": "Bridge monitoring"
    }
  },
  "fogo": {
    "transactions_with_instructions": {
      "description": "Fogo transactions with instructions",
      "version": "1.0.0",
      "datasetName": "fogo.transactions_with_instructions",
      "useCase": "Full activity tracking"
    },
    "rewards": {
      "description": "Fogo validator rewards",
      "version": "1.0.0",
      "datasetName": "fogo.rewards",
      "useCase": "Staking analysis"
    },
    "blocks": {
      "description": "Fogo block data",
      "version": "1.0.0",
      "datasetName": "fogo.blocks",
      "useCase": "Chain analysis"
    }
  }
}
